{
  "name": "@bwp-web/styles",
  "version": "2.0.0",
  "description": "SOLAR design tokens, Tailwind CSS preset, and styling utilities for Biamp Workplace",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./tokens.css": "./src/tokens.css",
    "./preset": {
      "import": {
        "types": "./dist/preset.d.ts",
        "default": "./dist/preset.js"
      },
      "require": {
        "types": "./dist/preset.d.ts",
        "default": "./dist/preset.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src/tokens.css"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "build:types": "tsc -p tsconfig.build.json",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "clean": "rm -rf dist node_modules .turbo",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "tailwindcss": ">=3.4.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@bwp-web/eslint-config": "*",
    "@types/react": "^19.1.0",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/evoko/workplace-public-packages.git",
    "directory": "packages/styles"
  }
}
